        </mxCell>
        <mxCell id="pboUPxhn2e-p1PuPumlf-127" parent="pboUPxhn2e-p1PuPumlf-126" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=12 12;fontSize=11;labelBackgroundColor=none;fillColor=#FAE5C7;strokeColor=#0F8B8D;fontColor=#143642;fillStyle=auto;imageAspect=0;" value="" vertex="1">
          <mxGeometry height="270" width="1211.63" y="-22" as="geometry" />
        </mxCell>
        <mxCell id="pboUPxhn2e-p1PuPumlf-128" connectable="0" parent="pboUPxhn2e-p1PuPumlf-126" style="group;fontSize=11;labelBackgroundColor=none;fontColor=#143642;" value="" vertex="1">
          <mxGeometry height="170" width="197.56" x="71.57000000000001" y="-2" as="geometry" />
        </mxCell>
        <mxCell id="pboUPxhn2e-p1PuPumlf-129" parent="pboUPxhn2e-p1PuPumlf-128" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;labelBackgroundColor=none;fillColor=#FAE5C7;strokeColor=#0F8B8D;fontColor=#143642;" value="&lt;span data-teams=&quot;true&quot;&gt;&lt;font&gt;&lt;b&gt;Includes two tasks:&lt;/b&gt;&lt;br&gt;First, a workflow which fetch all the relevant info from data fabric and also the attachment which user has uploaded&lt;br&gt;&lt;br&gt; Secondly, an Agent that reads the attachment and extract key details from the attachment such as if it has any concerning info or not.&lt;/font&gt;&lt;/span&gt;" vertex="1">
          <mxGeometry height="136" width="197.56000000000003" as="geometry" />
        </mxCell>
        <mxCell id="pboUPxhn2e-p1PuPumlf-130" parent="pboUPxhn2e-p1PuPumlf-128" style="text;html=1;whiteSpace=wrap;strokeColor=#36393d;fillColor=#eeeeee;align=center;verticalAlign=middle;rounded=0;fontSize=11;labelBackgroundColor=none;" value="&lt;font&gt;&lt;span data-teams=&quot;true&quot;&gt;Intake&lt;/span&gt;&amp;nbsp;Stage&lt;/font&gt;" vertex="1">
          <mxGeometry height="34" width="125.12133333333334" x="36.21933333333334" y="136" as="geometry" />
        </mxCell>
        <mxCell id="pboUPxhn2e-p1PuPumlf-131" edge="1" parent="pboUPxhn2e-p1PuPumlf-126" source="pboUPxhn2e-p1PuPumlf-129" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;labelBackgroundColor=none;strokeColor=#A8201A;fontColor=default;" target="pboUPxhn2e-p1PuPumlf-133" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pboUPxhn2e-p1PuPumlf-132" connectable="0" parent="pboUPxhn2e-p1PuPumlf-126" style="group;fontSize=11;labelBackgroundColor=none;fontColor=#143642;" value="" vertex="1">
          <mxGeometry height="200" width="229.4" x="305.57000000000005" y="-14" as="geometry" />
        </mxCell>
        <mxCell id="pboUPxhn2e-p1PuPumlf-133" parent="pboUPxhn2e-p1PuPumlf-132" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;labelBackgroundColor=none;fillColor=#FAE5C7;strokeColor=#0F8B8D;fontColor=#143642;" value="&lt;span data-teams=&quot;true&quot;&gt;&lt;font&gt;&lt;b&gt;Includes two tasks:&lt;/b&gt;&lt;br&gt;&lt;span data-teams=&quot;true&quot;&gt;Digital safety agent which analyse the input details and give a very structured output such as risk score, the action required and if the case needs to be escalated to NGOs/higher authority or if just parents needs to be made aware about the findings.&lt;br&gt;    The output of the agent goes to Action center for human review via UiPath Apps.&amp;nbsp;&lt;br&gt;    Based on the risk score it either goes in &#39;High Risk Path&#39; or &#39;Low Risk Path&#39;&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;" vertex="1">
          <mxGeometry height="160" width="229.4" as="geometry" />
        </mxCell>
        <mxCell id="pboUPxhn2e-p1PuPumlf-134" parent="pboUPxhn2e-p1PuPumlf-132" style="text;html=1;whiteSpace=wrap;strokeColor=#36393d;fillColor=#eeeeee;align=center;verticalAlign=middle;rounded=0;fontSize=11;labelBackgroundColor=none;" value="&lt;font&gt;&lt;span data-teams=&quot;true&quot;&gt;AI investigation&amp;nbsp;&lt;/span&gt;Stage&lt;/font&gt;" vertex="1">
          <mxGeometry height="40" width="90.80416666666667" x="69.29791666666667" y="160" as="geometry" />
        </mxCell>
        <mxCell id="pboUPxhn2e-p1PuPumlf-136" connectable="0" parent="pboUPxhn2e-p1PuPumlf-126" style="group;fontSize=11;labelBackgroundColor=none;fontColor=#143642;" value="" vertex="1">
          <mxGeometry height="88" width="438.43" x="581.57" y="-2" as="geometry" />
        </mxCell>
        <mxCell id="pboUPxhn2e-p1PuPumlf-137" parent="pboUPxhn2e-p1PuPumlf-136" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;labelBackgroundColor=none;fillColor=#FAE5C7;strokeColor=#0F8B8D;fontColor=#143642;" value="&lt;span data-teams=&quot;true&quot;&gt;&lt;font&gt;The &#39;High risk path&#39; is a UiPath app in Action center which provides details to a specialized reviewer who can review the AI agent&#39;s findings and can make some changes in the existing findings and need to add their own remarks and then choose to either &#39;submit&#39;, &#39;approve&#39; or &#39;escalate&#39;. &#39;submit&#39; which will send a mail to just the user whereas &#39;escalate&#39; will send mail to user as well as concerned authorities.&lt;/font&gt;&lt;/span&gt;" vertex="1">
